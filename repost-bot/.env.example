# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (only this user can operate the bot)
TELEGRAM_ALLOWED_USER_ID=123456789

# VK API (from https://vk.com/dev)
VK_COMMUNITY_TOKEN=your_community_token_here  # for wall.post
VK_USER_TOKEN=your_user_token_here            # for video upload (video.save requires user auth)
# Negative number for communities, e.g. -123456789
VK_OWNER_ID=-123456789

# Instagram Graph API (from https://developers.facebook.com)
INSTAGRAM_USER_ID=your_ig_user_id_here
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
